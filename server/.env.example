# 示例环境变量文件
# 复制此文件为 .env 并修改相应配置

# 服务器配置
PORT=8080
WSS_PORT=8443
DOMAIN=localhost

# SSL 配置
SSL_ENABLED=true
SSL_CERT_PATH=/app/certs/cert.pem
SSL_KEY_PATH=/app/certs/key.pem

# 应用配置
NODE_ENV=production

# JWT 配置（可选）
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=24h

# 数据库配置（可选）
DB_PATH=/app/data/browser-sync.db

# 日志配置
LOG_LEVEL=info
LOG_PATH=/app/logs
